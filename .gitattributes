# Normalise all text files to LF in the repo (cross-platform safe)
* text=auto eol=lf

# Force LF for code and config files
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.lock  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ipynb text eol=lf

# Binary files — never touch line endings
*.xlsx  binary
*.pkl   binary
*.png   binary
*.pdf   binary